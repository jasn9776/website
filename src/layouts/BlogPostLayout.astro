---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  heroImage: string;
  description?: string;
}

const { title, date, heroImage, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroImageSrc = `${base}/${heroImage.replace(/^\//, '')}`;

const formattedDate = new Date(date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <!-- Post header -->
    <header class="post-header">
      <div class="wrap">
        <div class="back-link-row">
          <a href={`${base}/blog`} class="back-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            All posts
          </a>
        </div>
        <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
        <h1>{title}</h1>
        {description && <p class="post-description">{description}</p>}
      </div>
    </header>

    <!-- Hero image -->
    <div class="hero-image">
      <img src={heroImageSrc} alt={title} />
    </div>

    <!-- Post body -->
    <div class="wrap">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-bottom: 120px;
  }

  .post-header {
    padding: 64px 0 48px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 0;
  }

  .back-link-row {
    margin-bottom: 40px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    text-decoration: none;
    transition: gap 0.3s ease, color 0.2s ease;
  }

  .back-link:hover {
    gap: 12px;
    color: var(--accent);
  }

  .post-date {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    margin-bottom: 20px;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-weight: 460;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--ink);
    max-width: 20ch;
    margin-bottom: 20px;
  }

  .post-description {
    font-size: 18px;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 56ch;
    margin-top: 16px;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Prose (blog body) typography */
  .prose {
    max-width: 68ch;
    margin: 64px auto 0;
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .prose :global(h2) {
    font-family: 'Fraunces', serif;
    font-weight: 460;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--ink);
    margin: 3rem 0 1rem;
  }

  .prose :global(h3) {
    font-family: 'Fraunces', serif;
    font-weight: 440;
    font-size: clamp(20px, 2.5vw, 28px);
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--ink);
    margin: 2.5rem 0 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-soft);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: var(--bg-card);
    border: 1px solid var(--line);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--ink);
  }

  .prose :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 2rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink);
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent-soft);
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: var(--ink-soft);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 3rem 0;
  }
</style>
