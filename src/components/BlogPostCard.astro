---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, heroImage, description } = post.data;
const href = `/blog/${post.slug}`;
const formattedDate = new Date(date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card">
  <a href={href} class="image-link" tabindex="-1" aria-hidden="true">
    <div class="card-image">
      <img src={heroImage} alt={title} />
    </div>
  </a>
  <div class="card-body">
    <time datetime={date.toISOString()} class="date">{formattedDate}</time>
    <h3><a href={href}>{title}</a></h3>
    {description && <p>{description}</p>}
    <a href={href} class="read-link">
      Read
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s ease,
      border-color 0.3s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -16px rgba(11, 23, 48, 0.15);
    border-color: var(--ink-soft);
  }

  .image-link {
    display: block;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .blog-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 24px 24px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .date {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: 12px;
  }

  h3 {
    font-family: 'Fraunces', serif;
    font-weight: 460;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
    color: var(--ink);
  }

  h3 a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h3 a:hover {
    color: var(--accent);
  }

  p {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin-bottom: 18px;
    flex: 1;
  }

  .read-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
    text-decoration: none;
    align-self: flex-start;
    transition: gap 0.3s ease, color 0.2s ease;
  }

  .read-link:hover {
    gap: 12px;
    color: var(--accent);
  }
</style>
